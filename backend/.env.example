SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=visit-media

ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_STT_MODEL=scribe_v2

# Groq free/OpenAI-compatible models.
GROQ_API_KEY=your-groq-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Or use any OpenAI-compatible free-model provider.
# OPENAI_COMPATIBLE_BASE_URL=https://provider.example/v1
# OPENAI_COMPATIBLE_API_KEY=your-provider-key
# AI_MODEL=provider/model-name

FRONTEND_URL=http://localhost:3000
MAX_UPLOAD_BYTES=104857600
